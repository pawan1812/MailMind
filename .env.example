# MailMind Environment Variables
# Copy to .env and fill in values

# ── Firebase (optional — server works without these) ─────────────
# FIREBASE_PROJECT_ID=mailmind-dev
# GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# ── Hackathon / Inference Script Requirements ────────────────────
# These are required to run inference.py properly
API_BASE_URL=http://localhost:7860  # Or the deployed HF Space URL
MODEL_NAME=gpt-4o-mini
# HF_TOKEN=hf_...  # Required if testing against Hugging Face

# ── OpenAI (optional — only for /baseline endpoint) ──────────────
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# ── App Config ───────────────────────────────────────────────────
DEBUG=false
LOG_LEVEL=info
